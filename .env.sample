# Azure AI Foundry Project Configuration
# Copy this file to .env and fill in your values

# Azure AI Project Connection String
# Format: <subscription-id>;<resource-group>;<project-name>
# You can find this in the Azure AI Foundry portal under your project settings
AZURE_AI_PROJECT_CONNECTION_STRING=

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure Subscription and Resource Group
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Azure AI Search (Optional - for knowledge retrieval)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=

# Application Insights (Optional - for monitoring)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Azure Storage (Optional - for file uploads)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

# Container App Configuration (Optional - for deployment)
AZURE_CONTAINER_APP_ENDPOINT=
